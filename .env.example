# Public origin of the deployment. REQUIRED in production when the app
# runs behind a reverse proxy / CDN (nginx, a China CDN, etc.), otherwise
# the OAuth redirect_uri is computed from the proxy's internal address
# (e.g. http://localhost:3000) and GitHub rejects the callback.
#   Production example: https://findfunplus.cn
# Leave empty for local dev — it falls back to forwarded headers / req.url.
APP_ORIGIN=

# GitHub OAuth — used only for displaying the user's GitHub avatar + name
# in the sidebar. Register an OAuth App at:
#   https://github.com/settings/developers
# The "Authorization callback URL" must match {APP_ORIGIN}/api/auth/github/callback
# exactly. A GitHub OAuth App allows only ONE callback URL, so use a
# separate OAuth App for local dev vs production:
#   local dev   →  https://localhost:3000/api/auth/github/callback
#   production  →  https://findfunplus.cn/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
